<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.PerfilPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="32,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Button Content="← Voltar" Click="VoltarBtn_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Text="Meu Perfil" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="860" HorizontalAlignment="Center"
                        Padding="32,28,32,40" Spacing="20">

                <!-- Card de identidade -->
                <Border Background="{ThemeResource PanelBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="28,24">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar com iniciais -->
                        <Border Grid.Column="0"
                                Width="72" Height="72"
                                Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AccentBrush}" BorderThickness="2"
                                CornerRadius="36">
                            <TextBlock x:Name="IniciaisTexto"
                                       Text="?"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock x:Name="NomeCompletoTexto"
                                       Text="—"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="FuncaoTexto"
                                       Text="—"
                                       FontSize="13"
                                       Foreground="{ThemeResource AccentBrush}"/>
                            <TextBlock x:Name="EmpresaTexto"
                                       Text="—"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Label seção -->
                <TextBlock Text="ESTATÍSTICAS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentBrush}" CharacterSpacing="150"
                           Margin="0,8,0,0"/>

                <!-- Grid de stats -->
                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Relatórios totais -->
                    <Border Grid.Column="0" Grid.Row="0"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE9F9;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="TotalRelatoriosTexto" Text="0"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Relatórios criados" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Relatórios este mês -->
                    <Border Grid.Column="1" Grid.Row="0"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE787;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="RelatoriosMesTexto" Text="0"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Relatórios este mês" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Horas em campo -->
                    <Border Grid.Column="2" Grid.Row="0"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE823;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="HorasTexto" Text="0h"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Horas em campo" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Dias em campo -->
                    <Border Grid.Column="0" Grid.Row="1"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xEC92;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="DiasTexto" Text="0"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Dias em campo" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Obras participadas -->
                    <Border Grid.Column="1" Grid.Row="1"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE825;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="ObrasTexto" Text="0"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Obras participadas" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Último relatório -->
                    <Border Grid.Column="2" Grid.Row="1"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="20,16">
                        <StackPanel Spacing="6">
                            <FontIcon Glyph="&#xE916;" FontSize="22"
                                      Foreground="{ThemeResource IconBrush}"/>
                            <TextBlock x:Name="UltimoRelTexto" Text="—"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Último relatório" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Últimas obras -->
                <TextBlock Text="OBRAS RECENTES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentBrush}" CharacterSpacing="150"
                           Margin="0,8,0,0"/>

                <ListView x:Name="ObrasRecentesList"
                          SelectionMode="None" Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"
                                               RadiusX="2" RadiusY="2"/>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="2">
                                        <TextBlock Text="{Binding Nome}" FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Grupo}" FontSize="11"
                                                   Foreground="{ThemeResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
