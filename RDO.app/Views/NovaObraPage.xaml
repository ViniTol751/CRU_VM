<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.NovaObraPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="32,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <Button Content="← Voltar" Click="VoltarBtn_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock x:Name="TituloTexto" Text="Nova Obra" FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="900"
                        HorizontalAlignment="Center"
                        Padding="32,28,32,40">

                <!-- Nome -->
                <StackPanel Spacing="8">
                    <TextBlock Text="NOME DA OBRA" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="NomeBox"
                             PlaceholderText="Ex: Subestação Itatiba 138kV"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 1: Grupo + Status -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="GRUPO / CLIENTE" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <TextBox x:Name="GrupoBox"
                                 PlaceholderText="Ex: Cargill, Siemens..."
                                 Background="{ThemeResource PanelBgBrush}"
                                 BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                 Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="STATUS" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <ComboBox x:Name="StatusBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}">
                            <ComboBoxItem Content="Em execução"/>
                            <ComboBoxItem Content="Concluída"/>
                            <ComboBoxItem Content="Paralisada"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Linha 2: Responsável Focus + Tipo de contrato -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="RESPONSÁVEL FOCUS" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <ComboBox x:Name="ResponsavelBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                  PlaceholderText="Selecione o responsável">
                            <ComboBoxItem Content="Bruno Pires"/>
                            <ComboBoxItem Content="Felipe Prado"/>
                            <ComboBoxItem Content="Juliana Bertoni"/>
                            <ComboBoxItem Content="Maicon Salomão"/>
                            <ComboBoxItem Content="Murilo Franco"/>
                            <ComboBoxItem Content="Wellington Bortolozo"/>
                            <ComboBoxItem Content="Wesley Gregório"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="TIPO DE CONTRATO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <ComboBox x:Name="TipoContratoBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}">
                            <ComboBoxItem Content="Contratante"/>
                            <ComboBoxItem Content="Contratada"/>
                            <ComboBoxItem Content="Supervisão de terceiros"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Linha 3: Contratante -->
                <StackPanel Spacing="8">
                    <TextBlock Text="RESPONSÁVEL CLIENTE" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="ContratanteBox"
                             PlaceholderText="Nome da empresa contratante"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 4: Endereço -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ENDEREÇO / LOCAL DA OBRA" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="EnderecoBox"
                             PlaceholderText="Ex: Rua das Flores, 123 — Indaiatuba/SP"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 5: ART -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ART / RRT" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="ArtBox"
                             PlaceholderText="Número da ART ou RRT"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 6: Datas -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="DATA DE INÍCIO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <DatePicker x:Name="DataInicioPicker"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="PREVISÃO DE TÉRMINO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <DatePicker x:Name="DataTerminoPicker"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Linha 7: Imagem -->
                <StackPanel Spacing="8">
                    <TextBlock Text="IMAGEM DA OBRA (.PNG)" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <Border x:Name="ImagemBorder"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="4" Height="140"
                            Tapped="ImagemBorder_Tapped">
                        <Grid>
                            <StackPanel x:Name="ImagemPlaceholder"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="8">
                                <FontIcon Glyph="&#xEB9F;" FontSize="32"
                                          Foreground="{ThemeResource AppBorderBrush}"/>
                                <TextBlock Text="Toque ou clique para adicionar uma imagem"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Image x:Name="PreviewImagem"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                            <Button x:Name="BtnRemoverImagem"
                                    Content="✕ Remover imagem"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,8,8,0"
                                    Padding="8,4"
                                    FontSize="11"
                                    Background="#1a1212"
                                    BorderBrush="#3a1a1a" BorderThickness="1"
                                    Foreground="#ff6666"
                                    Visibility="Collapsed"
                                    Click="RemoverImagem_Click"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="ImagemNomeTexto" FontSize="11"
                               Foreground="{ThemeResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Botões -->
                <Grid ColumnSpacing="16" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancelar"
                            HorizontalAlignment="Stretch" Height="44"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Click="VoltarBtn_Click"/>
                    <Button Grid.Column="1" x:Name="SalvarBtn"
                            Content="Criar Obra"
                            HorizontalAlignment="Stretch" Height="44"
                            Background="{ThemeResource AccentBrush}" BorderThickness="0"
                            Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                            Click="CriarBtn_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
