<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.NovaObraPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="32,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <Button Content="← Voltar" Click="VoltarBtn_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock x:Name="TituloTexto" Text="Nova Obra" FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="900"
                        HorizontalAlignment="Center"
                        Padding="32,28,32,40">

                <!-- Nome -->
                <StackPanel Spacing="8">
                    <TextBlock Text="NÚMERO DO CONTRATO INTERNO" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="NomeBox"
                             PlaceholderText="Ex: CS-001-26"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 1: Responsável Cliente + Status -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="RESPONSÁVEL CLIENTE" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <AutoSuggestBox x:Name="ResponsavelClienteBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                  PlaceholderText="Escreva para buscar..."
                                  TextChanged="ResponsavelCliente_TextChanged"
                                  SuggestionChosen="ResponsavelCliente_SuggestionChosen"
                                  QueryIcon="Clear"/>
                        <!-- Link para cadastrar terceiro -->
                        <HyperlinkButton Content="+ Não encontrou? Cadastre um novo terceiro"
                                         FontSize="11"
                                         Foreground="{ThemeResource AccentBrush}"
                                         Padding="0"
                                         Click="CadastrarTerceiro_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="STATUS" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <ComboBox x:Name="StatusBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}">
                            <ComboBoxItem Content="Em execução"/>
                            <ComboBoxItem Content="Concluída"/>
                            <ComboBoxItem Content="Paralisada"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Linha 2: Grupo + Responsável Focus -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="GRUPO / CLIENTE" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GrupoBox" Grid.Column="0"
                                     Background="{ThemeResource PanelBgBrush}"
                                     BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                     Foreground="{ThemeResource TextPrimaryBrush}" Height="44"
                                     IsReadOnly="True"
                                     GotFocus="GrupoBox_GotFocus"/>
                            <Button x:Name="BtnEditarGrupo" Grid.Column="1"
                                    Content="✏" Margin="8,0,0,0" Height="44" Width="44"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Desvincular Responsável para edição manual"
                                    Click="BtnEditarGrupoLocal_Click"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="RESPONSÁVEL FOCUS" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <ComboBox x:Name="ResponsavelBox"
                                  HorizontalAlignment="Stretch"
                                  Background="{ThemeResource PanelBgBrush}"
                                  BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                  PlaceholderText="Selecione o responsável">
                            <ComboBoxItem Content="Bruno Pires"/>
                            <ComboBoxItem Content="Felipe Prado"/>
                            <ComboBoxItem Content="Juliana Bertoni"/>
                            <ComboBoxItem Content="Maicon Salomão"/>
                            <ComboBoxItem Content="Murilo Franco"/>
                            <ComboBoxItem Content="Wellington Bortolozo"/>
                            <ComboBoxItem Content="Wesley Gregório"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Linha 3: Endereço -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ENDEREÇO / LOCAL DA OBRA" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="EnderecoBox" Grid.Column="0"
                                 PlaceholderText="Ex: Americana | SP"
                                 Background="{ThemeResource PanelBgBrush}"
                                 BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                 Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                        <Button x:Name="BtnEditarEndereco" Grid.Column="1"
                                Content="✏" Margin="8,0,0,0" Height="44" Width="44"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Desvincular Responsável para edição manual"
                                Click="BtnEditarGrupoLocal_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Linha 4: ART -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ART / RRT" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150"/>
                    <TextBox x:Name="ArtBox"
                             PlaceholderText="Número da ART ou RRT"
                             Background="{ThemeResource PanelBgBrush}"
                             BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                             Foreground="{ThemeResource TextPrimaryBrush}" Height="44"/>
                </StackPanel>

                <!-- Linha 6: Datas -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="DATA DE INÍCIO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <DatePicker x:Name="DataInicioPicker"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="PREVISÃO DE TÉRMINO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"
                                   CharacterSpacing="150"/>
                        <DatePicker x:Name="DataTerminoPicker"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"/>
                    </StackPanel>
                </Grid>



                <!-- Botões -->
                <Grid ColumnSpacing="16" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancelar"
                            HorizontalAlignment="Stretch" Height="44"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            Click="VoltarBtn_Click"/>
                    <Button Grid.Column="1" x:Name="SalvarBtn"
                            Content="Criar Obra"
                            HorizontalAlignment="Stretch" Height="44"
                            Background="{ThemeResource AccentBrush}" BorderThickness="0"
                            Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                            Click="CriarBtn_Click"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
