<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#xE72B;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Margin="0,0,16,0"
                        ToolTipService.ToolTip="Voltar"
                        Click="VoltarBtn_Click"/>

                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Ajuda" FontSize="20" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"/>
                    <TextBlock Text="Informações do sistema e documentos de apoio"
                               FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Conteúdo -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,24,28,24" Spacing="20" MaxWidth="720">

                <!-- Seção: Informações do Sistema -->
                <Border Background="{ThemeResource PanelBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE968;" FontSize="18"
                                      Foreground="{ThemeResource AccentBrush}"/>
                            <TextBlock Text="Informações do Sistema" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- URL da API (somente leitura) -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="URL da API:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6">
                                <TextBlock x:Name="ApiUrlTexto"
                                           Text="—"
                                           FontSize="12" FontFamily="Consolas"
                                           Foreground="{ThemeResource AccentBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <!-- Logos NAS -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Logos (NAS):"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6">
                                <TextBlock x:Name="NasPathTexto"
                                           Text="—"
                                           FontSize="12" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <!-- BD local (SQLite) -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="BD local:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Row="2" Grid.Column="1"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6">
                                <TextBlock x:Name="DbPathTexto"
                                           Text="—"
                                           FontSize="12" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <!-- BD central (PostgreSQL QNAP) -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="BD central:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Row="3" Grid.Column="1"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6">
                                <TextBlock x:Name="BdCentralTexto"
                                           Text="—"
                                           FontSize="12" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <!-- Diretório de dados local -->
                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Diretório dados:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Row="4" Grid.Column="1"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,6">
                                <TextBlock x:Name="DadosPathTexto"
                                           Text="—"
                                           FontSize="12" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <!-- Versão -->
                            <TextBlock Grid.Row="5" Grid.Column="0"
                                       Text="Versão:"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="1.0 — RDO App"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Para alterar a URL da API ou outras configurações de conexão, contate o administrador do sistema."
                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Seção: Logos das Empresas -->
                <Border Background="{ThemeResource PanelBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8B7;" FontSize="18"
                                      Foreground="{ThemeResource AccentBrush}"/>
                            <TextBlock Text="Logos das Empresas" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{ThemeResource TextSecondaryBrush}">
                            <Run Text="As logos são carregadas automaticamente do caminho de rede configurado (NAS) ou do armazenamento local. Para cadastrar ou atualizar a logo de uma empresa, acesse "/>
                            <Run Text="Cadastros → Empresas" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                            <Run Text=" e edite o registro da empresa."/>
                        </TextBlock>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="#00A36C" VerticalAlignment="Center"/>
                                <TextBlock Text="Formatos suportados: PNG (recomendado), JPG"
                                           FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="#00A36C" VerticalAlignment="Center"/>
                                <TextBlock Text="Resolução recomendada: 300×100 px ou superior"
                                           FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="12" Foreground="#00A36C" VerticalAlignment="Center"/>
                                <TextBlock Text="Fundo transparente ou branco para melhor resultado nos relatórios"
                                           FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Seção: Documentos de Apoio -->
                <Border Background="{ThemeResource PanelBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8A5;" FontSize="18"
                                      Foreground="{ThemeResource AccentBrush}"/>
                            <TextBlock Text="Documentos de Apoio" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Guias rápidos para as operações mais comuns do sistema:"
                                   FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>

                        <!-- Cards de ajuda — 3 colunas: ícone | texto | PDF -->
                        <StackPanel Spacing="8">

                            <!-- Como criar novos usuários -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE77B;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Como criar novos usuários"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Na tela de login, clique em 'Registrar Conta' e siga os passos do assistente."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- PDF: substitua o NavigateUri pelo link do Supabase -->
                                    <HyperlinkButton Grid.Column="2"
                                                     NavigateUri= "https://zoaakrwiqfudidmwziga.supabase.co/storage/v1/object/sign/DocumentosRDO/ANEXO%20A.pdf?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV83MzlkYzIwZi02YzRlLTRhMjQtYmM4ZC1jMGEwNjNmYTA1OTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJEb2N1bWVudG9zUkRPL0FORVhPIEEucGRmIiwiaWF0IjoxNzc3Mzk4ODg3LCJleHAiOjQ5MzA5OTg4ODd9.OGDrdCrkk3ru0qVTVMwuTSjWdUhuVNd22rcot5KrqEM"
                                                     VerticalAlignment="Center" Padding="6,4"
                                                     ToolTipService.ToolTip="Abrir documento PDF">
                                        <FontIcon Glyph="&#xEA90;" FontSize="18" Foreground="#E65050"/>
                                    </HyperlinkButton>
                                </Grid>
                            </Border>

                            <!-- Como resetar senha -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE72E;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Como resetar senha"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Na tela de login, clique em 'Esqueceu a senha?' e informe o usuário e a nova senha."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- PDF: substitua o NavigateUri pelo link do Supabase -->
                                    <HyperlinkButton Grid.Column="2"
                                                     NavigateUri="https://zoaakrwiqfudidmwziga.supabase.co/storage/v1/object/sign/DocumentosRDO/ANEXO%20A.pdf?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV83MzlkYzIwZi02YzRlLTRhMjQtYmM4ZC1jMGEwNjNmYTA1OTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJEb2N1bWVudG9zUkRPL0FORVhPIEEucGRmIiwiaWF0IjoxNzc3Mzk4ODg3LCJleHAiOjQ5MzA5OTg4ODd9.OGDrdCrkk3ru0qVTVMwuTSjWdUhuVNd22rcot5KrqEM"
                                                     VerticalAlignment="Center" Padding="6,4"
                                                     ToolTipService.ToolTip="Abrir documento PDF">
                                        <FontIcon Glyph="&#xEA90;" FontSize="18" Foreground="#E65050"/>
                                    </HyperlinkButton>
                                </Grid>
                            </Border>

                            <!-- Como criar uma nova obra -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE734;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Como criar uma nova obra"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Na tela Início, clique em '+ Nova Obra' no canto superior direito. Preencha os dados e salve."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="30" Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <!-- Como criar um novo relatório (RDO) -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Como criar um novo relatório (RDO)"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Na tela Início, clique no card de uma obra e depois em '+ Novo RDO'. Preencha as atividades, equipe e condições do dia."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="30" Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <!-- Como cadastrar equipamentos -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE8F9;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Como cadastrar equipamentos"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Acesse Cadastros → Equipamentos. O número de patrimônio segue o formato FC-XX, onde XX é o número sequencial (ex: FC-01, FC-12)."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="30" Visibility="Collapsed"/>
                                </Grid>
                            </Border>

                            <!-- Troubleshooting — Erros da aplicação -->
                            <Border Background="{ThemeResource AppBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            Background="{ThemeResource AccentSubtleBgBrush}" CornerRadius="6">
                                        <FontIcon Glyph="&#xE783;" FontSize="16"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="Troubleshooting — Erros da aplicação"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Guia completo com todos os códigos de erro, causas e passos para resolução. Consulte também o botão 'Resolução de Erros' na barra de sync."
                                                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- PDF: substitua o NavigateUri pelo link do Supabase -->
                                    <HyperlinkButton Grid.Column="2"
                                                     NavigateUri="https://zoaakrwiqfudidmwziga.supabase.co/storage/v1/object/sign/DocumentosRDO/ANEXO%20C.pdf?token=eyJraWQiOiJzdG9yYWdlLXVybC1zaWduaW5nLWtleV83MzlkYzIwZi02YzRlLTRhMjQtYmM4ZC1jMGEwNjNmYTA1OTIiLCJhbGciOiJIUzI1NiJ9.eyJ1cmwiOiJEb2N1bWVudG9zUkRPL0FORVhPIEMucGRmIiwiaWF0IjoxNzc3Mzk4OTYxLCJleHAiOjQ5MzA5OTg5NjF9.GGBxcO6mFPah13VkbC_P3vuOYUL23P22LF2Le7000iM"
                                                     VerticalAlignment="Center" Padding="6,4"
                                                     ToolTipService.ToolTip="Abrir guia de erros (PDF)">
                                        <FontIcon Glyph="&#xEA90;" FontSize="18" Foreground="#E65050"/>
                                    </HyperlinkButton>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Seção: Aparência -->
                <Border Background="{ThemeResource PanelBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE790;" FontSize="18"
                                      Foreground="{ThemeResource AccentBrush}"/>
                            <TextBlock Text="Aparência" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Tema do aplicativo"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="TemaAtualTexto"
                                           Text="Claro"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="BtnAlternarTema"
                                    Content="&#xE706;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="40" Height="40" Padding="0"
                                    Background="{ThemeResource AccentSubtleBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6"
                                    Foreground="{ThemeResource AccentBrush}"
                                    Click="BtnAlternarTema_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
