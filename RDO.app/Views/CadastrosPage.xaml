<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.CadastrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDO.App.Converters"
    NavigationCacheMode="Required"
    Background="{ThemeResource AppBgBrush}">

    <Page.Resources>
        <local:NullableDateConverter x:Key="DateFormatConverter"/>
        <local:ImagePathConverter x:Key="LogoConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Page.Resources>

    <Grid Margin="0,44,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="&#xE72B;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="36" Height="36" Padding="0"
                        Background="Transparent"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Margin="0,0,16,0"
                        ToolTipService.ToolTip="Voltar"
                        Click="VoltarBtn_Click"/>

                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Cadastros" FontSize="20" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gerencie empresas, obras, funcionários e equipamentos"
                               FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Abas -->
        <Border Grid.Row="1" Background="{ThemeResource PanelBgBrush}"
        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="28,0">
            <StackPanel Orientation="Horizontal" Spacing="0">
                <Button x:Name="BtnAbaEmpresas" Content="Empresas"
                Padding="20,14" BorderThickness="0"
                Background="Transparent"
                Click="BtnAbaEmpresas_Click"/>
                <Button x:Name="BtnAbaObras" Content="Obras"
                Padding="20,14" BorderThickness="0,0,0,2"
                Background="Transparent"
                Click="BtnAbaObras_Click"/>
                <Button x:Name="BtnAbaFuncionarios" Content="Funcionários"
                Padding="20,14" BorderThickness="0"
                Background="Transparent"
                Click="BtnAbaFuncionarios_Click"/>
                <Button x:Name="BtnAbaEquipamentos" Content="Equipamentos"
                Padding="20,14" BorderThickness="0"
                Background="Transparent"
                Click="BtnAbaEquipamentos_Click"/>
                <Button x:Name="BtnAbaAcompanhantes" Content="Acompanhante Técnico"
                Padding="20,14" BorderThickness="0"
                Background="Transparent"
                Click="BtnAbaAcompanhantes_Click"/>
            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <ScrollViewer Grid.Row="2" Padding="28"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- ABA: Empresas -->
                <StackPanel x:Name="PainelEmpresas" Visibility="Collapsed" Spacing="12">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="6" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>

                                <TextBox x:Name="BuscaEmpresasBox"
                         Grid.Column="1"
                         PlaceholderText="Buscar por nome..."
                         Background="Transparent" BorderThickness="0"
                         Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                         TextChanged="BuscaEmpresas_TextChanged"/>

                                <Button x:Name="LimparBuscaEmpresasBtn"
                        Grid.Column="2"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                        Visibility="Collapsed"
                        Click="LimparBuscaEmpresas_Click"/>
                            </Grid>
                        </Border>

                        <Button x:Name="SortEmpresasBtn" Grid.Column="1"
                                Height="40" Width="44" CornerRadius="6" Padding="0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="11" FontWeight="SemiBold"
                                Content="A↑" ToolTipService.ToolTip="Ordenar A → Z"
                                Click="SortEmpresas_Click"/>

                        <Border Grid.Column="2" Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,0" Height="40" VerticalAlignment="Center">
                            <TextBlock x:Name="EmpresasCountText"
                                       Text="0 registros"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button Grid.Column="3" Height="40" Padding="12,0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                ToolTipService.ToolTip="Exportar lista como CSV"
                                Click="ExportarEmpresas_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{ThemeResource AccentBrush}"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Content="+ Nova Empresa"
                Height="40"
                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                Click="AdicionarEmpresa_Click"/>
                    </Grid>

                    <ListView x:Name="EmpresasListView"
              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
                                    <Grid MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"/>

                                        <!-- Thumbnail -->
                                        <Border Grid.Column="1" Width="44" Height="44"
                            CornerRadius="4"
                            Background="White"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Grid>
                                                <FontIcon Glyph="&#xE731;" FontSize="18"
                                  Foreground="{ThemeResource TextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding LogoUrl, Converter={StaticResource NullToVisibility}}"/>
                                                <Image Stretch="Uniform" Margin="3"
                                   Source="{Binding LogoUrl, Converter={StaticResource LogoConverter}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Nome -->
                                        <StackPanel Grid.Column="2" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="EMPRESA"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Nome}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                            Spacing="6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                                            <Button Content="✏" Width="34" Height="34"
                            Background="{ThemeResource EditBtnBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource TextTertiaryBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="EditarEmpresa_Click"/>
                                            <Button Content="🗑" Width="34" Height="34"
                            Background="{ThemeResource DangerBgBrush}"
                            BorderBrush="{ThemeResource DangerBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource DangerFgBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="ExcluirEmpresa_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

                <!-- ABA: Obras -->
                <StackPanel x:Name="PainelObras" Visibility="Collapsed" Spacing="12">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="6" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>

                                <TextBox x:Name="BuscaObrasBox"
                         Grid.Column="1"
                         PlaceholderText="Buscar por nome, grupo, contratante ou responsável..."
                         Background="Transparent" BorderThickness="0"
                         Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                         TextChanged="BuscaObras_TextChanged"/>

                                <Button x:Name="LimparBuscaObrasBtn"
                        Grid.Column="2"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                        Visibility="Collapsed"
                        Click="LimparBuscaObras_Click"/>
                            </Grid>
                        </Border>

                        <Button x:Name="SortObrasBtn" Grid.Column="1"
                                Height="40" Width="44" CornerRadius="6" Padding="0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="14"
                                Content="&#xE8CB;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTipService.ToolTip="Mais antigas primeiro (por nº contrato)"
                                Click="SortObras_Click"/>

                        <Border Grid.Column="2" Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,0" Height="40" VerticalAlignment="Center">
                            <TextBlock x:Name="ObrasCountText"
                                       Text="0 registros"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button x:Name="BtnMostrarInativas" Grid.Column="3"
                                Height="40" Padding="14,0"
                                Background="Transparent"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                Content="Mostrar inativas"
                                Click="BtnMostrarInativas_Click"/>

                        <Button x:Name="ExportarObrasBtn" Grid.Column="4"
                                Height="40" Padding="12,0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                ToolTipService.ToolTip="Exportar lista como CSV"
                                Click="ExportarObras_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{ThemeResource AccentBrush}"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5" Content="+ Adicionar"
                Height="40"
                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                Click="AdicionarObra_Click"/>
                    </Grid>

                    <ListView x:Name="ObrasListViewCadastro"
              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="0">
                                    <Grid MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"/>

                                        <!-- Status -->
                                        <StackPanel Grid.Column="1" Spacing="4"
                Padding="10,14" VerticalAlignment="Center">
                                            <TextBlock Text="STATUS"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <Border Background="{ThemeResource AccentSubtleBgBrush}"
                BorderBrush="{ThemeResource AccentBrush}" BorderThickness="1"
                CornerRadius="2" Padding="6,3"
                HorizontalAlignment="Left"
                Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Status}"
                       FontSize="10" Foreground="{ThemeResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Nome + Endereço -->
                                        <StackPanel Grid.Column="2" Spacing="4"
                Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="OBRA"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Nome}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Endereco}"
                   FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Grupo/Cliente -->
                                        <StackPanel Grid.Column="3" Spacing="4"
                Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="GRUPO / CLIENTE"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Grupo}"
                   FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                   Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Responsável Cliente -->
                                        <StackPanel Grid.Column="4" Spacing="4"
                Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="RESP. CLIENTE"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding ResponsavelCliente}"
                   FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                   Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Responsável Focus -->
                                        <StackPanel Grid.Column="5" Spacing="4"
                Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="RESP. FOCUS"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Responsavel}"
                   FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                   Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Período -->
                                        <StackPanel Grid.Column="6" Spacing="4"
                Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="PERÍODO"
                   FontSize="9" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding DataInicio, Converter={StaticResource DateFormatConverter}}"
                   FontSize="12" Foreground="{ThemeResource TextTertiaryBrush}"
                   Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding PrevisaoTermino, Converter={StaticResource DateFormatConverter}}"
                   FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="7" Orientation="Horizontal"
                Spacing="6" Margin="0,0,12,0"
                VerticalAlignment="Center">
                                            <Button Content="✏" Width="34" Height="34"
                Background="{ThemeResource EditBtnBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                Foreground="{ThemeResource TextTertiaryBrush}" Padding="0"
                Tag="{Binding}"
                Click="EditarObra_Click"/>
                                            <Button Content="🗑" Width="34" Height="34"
                Background="{ThemeResource DangerBgBrush}"
                BorderBrush="{ThemeResource DangerBorderBrush}" BorderThickness="1"
                Foreground="{ThemeResource DangerFgBrush}" Padding="0"
                Tag="{Binding}"
                Click="ExcluirObra_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Seção: obras desativadas (oculta por padrão) -->
                    <StackPanel x:Name="PainelObrasInativas" Visibility="Collapsed" Spacing="8">
                        <Border Background="{ThemeResource AppBorderBrush}" Height="1" Margin="0,4,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="OBRAS DESATIVADAS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="120"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ContadorInativasTexto" Grid.Column="1"
                                       Text="" FontSize="11"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ListView x:Name="ObrasInativasListView"
                                  SelectionMode="None" Background="Transparent"
                                  MaxHeight="480">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource PanelBgBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1" CornerRadius="4" Padding="16,12"
                                            Opacity="0.7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding Nome}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Grupo}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <Button Grid.Column="2"
                                                    Content="Reativar"
                                                    Height="32" Padding="14,0"
                                                    Background="{ThemeResource AccentSubtleBgBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                                    Foreground="{ThemeResource AccentBrush}"
                                                    FontSize="12"
                                                    Tag="{Binding}"
                                                    Click="ReativarObra_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                </StackPanel>

                <!-- ABA: Funcionários -->
                <StackPanel x:Name="PainelFuncionarios" Spacing="12">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Barra de busca com ícone e botão limpar -->
                        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="6" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>

                                <TextBox x:Name="BuscaFuncionariosBox"
                         Grid.Column="1"
                         PlaceholderText="Buscar por nome, função, empresa ou contato..."
                         Background="Transparent" BorderThickness="0"
                         Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                         TextChanged="BuscaFuncionarios_TextChanged"/>

                                <Button x:Name="LimparBuscaFuncionariosBtn"
                        Grid.Column="2"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                        Visibility="Collapsed"
                        Click="LimparBuscaFuncionarios_Click"/>
                            </Grid>
                        </Border>

                        <Button x:Name="SortFuncionariosBtn" Grid.Column="1"
                                Height="40" Width="44" CornerRadius="6" Padding="0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="11" FontWeight="SemiBold"
                                Content="A↑" ToolTipService.ToolTip="Ordenar A → Z"
                                Click="SortFuncionarios_Click"/>

                        <Border Grid.Column="2" Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,0" Height="40" VerticalAlignment="Center">
                            <TextBlock x:Name="FuncionariosCountText"
                                       Text="0 registros"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button Grid.Column="3" Height="40" Padding="12,0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                ToolTipService.ToolTip="Exportar lista como CSV"
                                Click="ExportarFuncionarios_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{ThemeResource AccentBrush}"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Content="+ Adicionar"
                Height="40"
                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                Click="AdicionarFuncionario_Click"/>
                    </Grid>

                    <ListView x:Name="FuncionariosListView"
              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
                                    <Grid MinHeight="56">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="260"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"/>

                                        <!-- Tipo -->
                                        <StackPanel Grid.Column="1" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="TIPO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <Border Background="{ThemeResource AccentSubtleBgBrush}"
                            BorderBrush="{ThemeResource AccentBrush}" BorderThickness="1"
                            CornerRadius="2" Padding="8,4"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0">

                                                <TextBlock Text="{Binding Tipo}"
                                   FontSize="11" Foreground="{ThemeResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Nome -->
                                        <StackPanel Grid.Column="2" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="NOME"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Nome}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Função -->
                                        <StackPanel Grid.Column="3" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="FUNÇÃO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Funcao}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Empresa -->
                                        <StackPanel Grid.Column="4" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="EMPRESA"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Empresa}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Contato -->
                                        <StackPanel Grid.Column="5" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="CONTATO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Contato}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="6" Orientation="Horizontal"
                            Spacing="6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                                            <Button Content="✏" Width="34" Height="34"
                            Background="{ThemeResource EditBtnBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource TextTertiaryBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="EditarFuncionario_Click"/>
                                            <Button Content="🗑" Width="34" Height="34"
                            Background="{ThemeResource DangerBgBrush}"
                            BorderBrush="{ThemeResource DangerBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource DangerFgBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="ExcluirFuncionario_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

                <!-- ABA: Equipamentos -->
                <StackPanel x:Name="PainelEquipamentos" Visibility="Collapsed" Spacing="12">

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="6" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>

                                <TextBox x:Name="BuscaEquipamentosBox"
                         Grid.Column="1"
                         PlaceholderText="Buscar por nome, categoria ou número de série..."
                         Background="Transparent" BorderThickness="0"
                         Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                         TextChanged="BuscaEquipamentos_TextChanged"/>

                                <Button x:Name="LimparBuscaEquipamentosBtn"
                        Grid.Column="2"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                        Visibility="Collapsed"
                        Click="LimparBuscaEquipamentos_Click"/>
                            </Grid>
                        </Border>

                        <Button x:Name="SortEquipamentosBtn" Grid.Column="1"
                                Height="40" Width="44" CornerRadius="6" Padding="0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="14"
                                Content="&#xE8CB;"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTipService.ToolTip="Menor patrimônio primeiro (FC-01 → FC-XX)"
                                Click="SortEquipamentos_Click"/>

                        <Border Grid.Column="2" Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,0" Height="40" VerticalAlignment="Center">
                            <TextBlock x:Name="EquipamentosCountText"
                                       Text="0 registros"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button Grid.Column="3" Height="40" Padding="12,0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                ToolTipService.ToolTip="Exportar lista como CSV"
                                Click="ExportarEquipamentos_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{ThemeResource AccentBrush}"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Content="+ Adicionar"
                Height="40"
                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                Click="AdicionarEquipamento_Click"/>
                    </Grid>

                    <ListView x:Name="EquipamentosListView"
              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
                                    <Grid MinHeight="56">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="280"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Barra verde -->
                                        <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"/>

                                        <!-- Nº Patrimônio -->
                                        <StackPanel Grid.Column="1" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="PATRIMÔNIO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding NumeroSerie}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- Nome -->
                                        <StackPanel Grid.Column="2" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="EQUIPAMENTO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Nome}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Fabricante -->
                                        <StackPanel Grid.Column="3" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="FABRICANTE"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Fabricante}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"                                                       
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Modelo -->
                                        <StackPanel Grid.Column="4" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="MODELO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Modelo}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"                       
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                            Spacing="6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                                            <Button Content="✏" Width="34" Height="34"
                            Background="{ThemeResource EditBtnBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource TextTertiaryBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="EditarEquipamento_Click"/>
                                            <Button Content="🗑" Width="34" Height="34"
                            Background="{ThemeResource DangerBgBrush}"
                            BorderBrush="{ThemeResource DangerBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource DangerFgBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="ExcluirEquipamento_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

                <!-- ABA: Acompanhante Técnico -->
                <StackPanel x:Name="PainelAcompanhantes" Visibility="Collapsed" Spacing="12">

                    <!-- Banner: sem empresas cadastradas -->
                    <Border x:Name="BannerSemEmpresas"
                            Visibility="Collapsed"
                            Background="{ThemeResource AccentSubtleBgBrush}"
                            BorderBrush="{ThemeResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7BA;"
                                      Foreground="{ThemeResource AccentBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Para vincular um acompanhante a uma empresa, cadastre uma empresa primeiro."
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       MaxWidth="500"/>
                            <Button Content="Ir para Empresas"
                                    Click="IrParaEmpresas_Click"
                                    Background="{ThemeResource AccentBrush}"
                                    Foreground="{ThemeResource AccentFgBrush}"
                                    BorderThickness="0"
                                    Padding="12,6"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="6" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="&#xE721;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14" Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,8,0"/>

                                <TextBox x:Name="BuscaAcompanhantesBox"
                         Grid.Column="1"
                         PlaceholderText="Buscar por nome, cargo ou grupo..."
                         Background="Transparent" BorderThickness="0"
                         Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                         TextChanged="BuscaAcompanhantes_TextChanged"/>

                                <Button x:Name="LimparBuscaAcompanhantesBtn"
                        Grid.Column="2"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                        Visibility="Collapsed"
                        Click="LimparBuscaAcompanhantes_Click"/>
                            </Grid>
                        </Border>

                        <Button x:Name="SortAcompanhantesBtn" Grid.Column="1"
                                Height="40" Width="44" CornerRadius="6" Padding="0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="11" FontWeight="SemiBold"
                                Content="A↑" ToolTipService.ToolTip="Ordenar A → Z"
                                Click="SortAcompanhantes_Click"/>

                        <Border Grid.Column="2" Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12,0" Height="40" VerticalAlignment="Center">
                            <TextBlock x:Name="AcompanhantesCountText"
                                       Text="0 registros"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Button Grid.Column="3" Height="40" Padding="12,0"
                                Background="{ThemeResource PanelBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                ToolTipService.ToolTip="Exportar lista como CSV"
                                Click="ExportarAcompanhantes_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" Foreground="{ThemeResource AccentBrush}"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4" Content="+ Adicionar"
                Height="40"
                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                Click="AdicionarAcompanhante_Click"/>
                    </Grid>

                    <ListView x:Name="AcompanhantesListView"
              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
                                    <Grid MinHeight="56">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="260"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <Rectangle Grid.Column="0" Fill="{ThemeResource AccentBrush}"/>

                                        <!-- Nome -->
                                        <StackPanel Grid.Column="1" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="NOME"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Nome}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding EmpresaNome}"
                               FontSize="11"
                               Foreground="{ThemeResource AccentBrush}"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Cargo -->
                                        <StackPanel Grid.Column="2" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="CARGO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Cargo}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Grupo/Cliente -->
                                        <StackPanel Grid.Column="3" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="GRUPO / CLIENTE"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <Border Background="{ThemeResource AccentSubtleBgBrush}"
                            BorderBrush="{ThemeResource AccentBrush}" BorderThickness="1"
                            CornerRadius="2" Padding="8,4"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Grupo}"
                                   FontSize="11" Foreground="{ThemeResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Contato -->
                                        <StackPanel Grid.Column="4" Spacing="4"
                            Padding="12,14" VerticalAlignment="Center">
                                            <TextBlock Text="CONTATO"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                            <TextBlock Text="{Binding Contato}"
                               FontSize="13" Foreground="{ThemeResource TextTertiaryBrush}"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Botões -->
                                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                            Spacing="6" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                                            <Button Content="✏" Width="34" Height="34"
                            Background="{ThemeResource EditBtnBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource TextTertiaryBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="EditarAcompanhante_Click"/>
                                            <Button Content="🗑" Width="34" Height="34"
                            Background="{ThemeResource DangerBgBrush}"
                            BorderBrush="{ThemeResource DangerBorderBrush}" BorderThickness="1"
                            Foreground="{ThemeResource DangerFgBrush}" Padding="0"
                            Tag="{Binding}"
                            Click="ExcluirAcompanhante_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>
                <!-- fim ABA Acompanhante Técnico -->

            </StackPanel>
            <!-- fim StackPanel externo -->

        </ScrollViewer>
    </Grid>
</Page>