<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDO.App.Converters"
    Background="{ThemeResource AppBgBrush}">

    <Page.Resources>
        <local:NullableDateConverter x:Key="DateFormatConverter"/>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="0,44,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Navegação -->
                <StackPanel Grid.Row="0" Margin="0,8,0,0" Spacing="2">
                    <Button x:Name="BtnInicio"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="24,12" BorderThickness="0"
                            Click="BtnInicio_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE80F;" FontSize="16"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Início" FontSize="14"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnMinhasObras"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="24,12" Background="Transparent"
                            BorderThickness="0"
                            Click="BtnMinhasObras_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE734;" FontSize="16"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Relatórios" FontSize="14"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRascunhos"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="24,12" Background="Transparent"
                            BorderThickness="0"
                            Click="BtnRascunhos_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE70B;" FontSize="16"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Rascunhos" FontSize="14"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Height="1" Fill="{ThemeResource AppBorderBrush}" Margin="16,8"/>

                    <Button x:Name="BtnCadastros"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="24,12" Background="Transparent"
                            BorderThickness="0"
                            Click="BtnCadastros_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8FA;" FontSize="16"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Cadastros" FontSize="14"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnConfiguracoes"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="24,12" Background="Transparent"
                            BorderThickness="0"
                            Click="BtnConfiguracoes_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE897;" FontSize="16"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                            <TextBlock Text="Ajuda" FontSize="14"
                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Usuário + Tema -->
                <Border Grid.Row="1" Padding="14,12"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,1,0,0">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar / ícone de perfil -->
                        <Button Grid.Column="0"
                                x:Name="BtnPerfil"
                                Width="36" Height="36" Padding="0"
                                Background="{ThemeResource AccentSubtleBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                CornerRadius="18"
                                ToolTipService.ToolTip="Ver perfil"
                                Click="BtnPerfil_Click">
                            <FontIcon x:Name="IconePerfil"
                                      Glyph="&#xE77B;"
                                      FontSize="16"
                                      Foreground="{ThemeResource IconBrush}"/>
                        </Button>

                        <!-- Nome + cargo -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <TextBlock x:Name="NomeUsuarioTexto"
                                       Text="Usuário"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PerfilUsuarioTexto"
                                       Text="—"
                                       FontSize="10"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Tema -->
                        <Button x:Name="BtnTema"
                                Grid.Column="2"
                                Content="&#xE706;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="32" Height="32" Padding="0"
                                Background="Transparent"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}"
                                ToolTipService.ToolTip="Alternar tema"
                                Click="BtnTema_Click"/>

                        <!-- Sair -->
                        <Button Grid.Column="3"
                                Content="&#xE7E8;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="32" Height="32" Padding="0"
                                Background="Transparent"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                ToolTipService.ToolTip="Sair"
                                Click="SairBtn_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Painel principal -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TituloPagina" Text="Início"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{ThemeResource AccentBrush}" CornerRadius="10"
                                Padding="8,2" VerticalAlignment="Center">
                            <TextBlock x:Name="TotalObrasTexto" Text="0"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentFgBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Área de sync + nova obra (direita) -->
                    <StackPanel Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="Right" VerticalAlignment="Center">

                        <!-- Indicador de status de sync -->
                        <Border x:Name="SyncStatusBadge"
                                CornerRadius="6" Padding="10,4"
                                Background="{ThemeResource AppBorderBrush}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="SyncStatusIcon"
                                          Glyph="&#xE895;"
                                          FontSize="12"
                                          Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="SyncStatusTexto"
                                           Text="Verificando..."
                                           FontSize="11"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Botão Ver Logs (só visível em erro) -->
                        <Button x:Name="BtnVerLogs"
                                Visibility="Collapsed"
                                Height="34" Padding="10,0"
                                Background="Transparent"
                                BorderBrush="#5A1E1E" BorderThickness="1"
                                CornerRadius="6"
                                ToolTipService.ToolTip="Abrir pasta de logs"
                                Click="BtnVerLogs_Click">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE8B7;" FontSize="11" Foreground="#E65050"/>
                                <TextBlock Text="Ver logs" FontSize="11" Foreground="#E65050"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Botão Guia de Erros (só visível em erro) -->
                        <Button x:Name="BtnGuiaErros"
                                Visibility="Collapsed"
                                Width="34" Height="34" Padding="0"
                                Background="Transparent"
                                BorderBrush="#5A1E1E" BorderThickness="1"
                                Foreground="#E65050"
                                ToolTipService.ToolTip="Como resolver erros de sincronização"
                                Click="BtnGuiaErros_Click">
                            <FontIcon Glyph="&#xE897;" FontSize="14" Foreground="#E65050"/>
                        </Button>

                        <!-- Botão de sync manual -->
                        <Button x:Name="BtnSync"
                                Content="&#xE895;"
                                FontFamily="Segoe MDL2 Assets"
                                Width="34" Height="34" Padding="0"
                                Background="Transparent"
                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                Foreground="{ThemeResource AccentBrush}"
                                ToolTipService.ToolTip="Sincronizar agora"
                                Click="BtnSync_Click"/>

                        <Button x:Name="BtnNovaObra" Content="+ Nova Obra"
                                Height="34" Padding="16,0"
                                Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                FontSize="13"
                                Click="BtnNovaObra_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Barra de filtros (obras) -->
            <Border x:Name="FiltroBar"
                    Grid.Row="1" Background="{ThemeResource PanelBgBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <!-- Busca -->
                    <Border Grid.Column="0" Background="{ThemeResource InputBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Height="36">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,8,0"/>
                            <TextBox x:Name="BuscaObrasBox"
                                     Grid.Column="1"
                                     PlaceholderText="Buscar obra..."
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     VerticalAlignment="Center"
                                     TextChanged="BuscaObras_TextChanged"/>
                            <Button x:Name="LimparBuscaBtn"
                                    Grid.Column="2"
                                    Content="&#xE711;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="30" Height="30"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource TextSecondaryBrush}" Padding="0"
                                    Visibility="Collapsed"
                                    Click="LimparBusca_Click"/>
                        </Grid>
                    </Border>

                    <!-- Filtro Status -->
                    <ComboBox x:Name="FiltroStatusBox"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Height="36"
                              Background="{ThemeResource InputBgBrush}"
                              BorderBrush="{ThemeResource AppBorderBrush}"
                              Foreground="{ThemeResource TextPrimaryBrush}"
                              SelectionChanged="FiltroStatus_Changed">
                        <ComboBoxItem Content="Todos os status" IsSelected="True"/>
                        <ComboBoxItem Content="Em execução"/>
                        <ComboBoxItem Content="Concluída"/>
                        <ComboBoxItem Content="Paralisada"/>
                    </ComboBox>

                    <!-- Subtítulo -->
                    <TextBlock x:Name="SubtituloLista"
                               Grid.Column="2"
                               Text="Todas as obras"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               CharacterSpacing="120"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- KPI Dashboard (só visível na aba Início) -->
            <Border x:Name="KpiBar"
                    Grid.Row="2"
                    Background="{ThemeResource AppBgBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,14">
                <StackPanel Orientation="Horizontal" Spacing="14">

                    <!-- Em execução -->
                    <Border Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" MinWidth="140">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="2" Background="#00A36C"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="KpiEmExecucao" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock Text="EM EXECUÇÃO"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           CharacterSpacing="100"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Concluídas -->
                    <Border Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" MinWidth="140">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="2" Background="#0078D4"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="KpiConcluidas" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock Text="CONCLUÍDAS"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           CharacterSpacing="100"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Paralisadas -->
                    <Border Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" MinWidth="140">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="2" Background="#C42B2B"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="KpiParalisadas" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock Text="PARALISADAS"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           CharacterSpacing="100"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- RDOs este mês -->
                    <Border Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" MinWidth="150">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="2" Background="#7B68EE"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="KpiRdosMes" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock Text="RDOs ESTE MÊS"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           CharacterSpacing="100"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Rascunhos abertos -->
                    <Border Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16,12" MinWidth="150">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="2" Background="#E69500"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="KpiRascunhos" Text="—"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"/>
                                <TextBlock Text="RASCUNHOS"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           CharacterSpacing="100"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- Grid de cards (obras) -->
            <ScrollViewer x:Name="ObrasPanel"
                          Grid.Row="3" Padding="28"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ObrasItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8,0,8">

                                <!-- Cabeçalho do grupo -->
                                <TextBlock Text="{Binding Grupo}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <Rectangle Height="1"
                                           Fill="{ThemeResource AppBorderBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- Estado vazio -->
                                <StackPanel Visibility="{Binding SemObras, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Orientation="Horizontal" Spacing="10"
                                            Padding="4,0,0,8">
                                    <FontIcon Glyph="&#xE74D;" FontSize="16"
                                              Foreground="{ThemeResource AppBorderBrush}"/>
                                    <TextBlock Text="Nenhuma obra"
                                               FontSize="13"
                                               Foreground="{ThemeResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Grid de obras -->
                                <ItemsControl ItemsSource="{Binding Obras}"
                                              Visibility="{Binding TemObras, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal"
                                                           ItemWidth="296"
                                                           MaximumRowsOrColumns="10"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="280"
                                                    Margin="0,0,0,12"
                                                    Background="{ThemeResource PanelBgBrush}"
                                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                                    CornerRadius="8"
                                                    Tapped="ObraCard_Tapped"
                                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="160"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Imagem / Placeholder -->
                                    <Grid Grid.Row="0" CornerRadius="8,8,0,0">
                                        <Border Background="{ThemeResource CardImgBgBrush}"
                                                CornerRadius="8,8,0,0">
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Spacing="8">
                                                <FontIcon Glyph="&#xE825;" FontSize="40"
                                                          Foreground="{ThemeResource IconBrush}"/>
                                                <TextBlock Text="Sem imagem" FontSize="11"
                                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Logo da empresa: fundo branco so aparece quando ha logo -->
                                        <Border CornerRadius="8,8,0,0" Padding="16" Background="White"
                                                Visibility="{Binding HasEmpresaLogo, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Image Source="{Binding EmpresaLogoUrl, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="Uniform"/>
                                        </Border>

                                        <!-- Foto da obra (cobre o logo quando disponivel) -->
                                        <Border CornerRadius="8,8,0,0">
                                            <Image Source="{Binding ImagemPath, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Badge rascunho -->
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,10,10,0"
                                                CornerRadius="4" Padding="8,4"
                                                Background="#f59e0b"
                                                Visibility="{Binding TemRascunho, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE70B;" FontSize="10"
                                                          Foreground="White"/>
                                                <TextBlock Text="Rascunho"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Badge prazo vencido -->
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="10,10,0,0"
                                                CornerRadius="4" Padding="8,4"
                                                Background="#dc2626"
                                                Visibility="{Binding PrazoVencido, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE783;" FontSize="10"
                                                          Foreground="White"/>
                                                <TextBlock Text="Prazo vencido"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Quantidade RDOs -->
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Margin="10,0,0,10"
                                                Background="{ThemeResource InputBgBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4" Padding="8,4">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE736;"
                                                          FontSize="11"
                                                          Foreground="{ThemeResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding QtdRdos}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </Border>

                                    </Grid>

                                    <!-- Informações -->
                                    <StackPanel Grid.Row="1" Spacing="6"
                                                Padding="14,12,14,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Nome}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <Border Grid.Column="1"
                                                    CornerRadius="4" Padding="8,4"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding StatusBackground}"
                                                    Opacity="0.92">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Grupo}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource AccentBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Endereco}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="INÍCIO"
                                                           FontSize="9"
                                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold"
                                                           CharacterSpacing="100"/>
                                                <TextBlock Text="{Binding DataInicio, Converter={StaticResource DateFormatConverter}}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="TÉRMINO PREV."
                                                           FontSize="9"
                                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                                           FontWeight="SemiBold"
                                                           CharacterSpacing="100"/>
                                                <TextBlock Text="{Binding PrevisaoTermino, Converter={StaticResource DateFormatConverter}}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Lista de Meus Relatórios -->
            <ScrollViewer x:Name="RelatoriosPanel"
                          Grid.Row="3"
                          Visibility="Collapsed"
                          Padding="28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Text="RELATÓRIOS" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150" Margin="0,0,0,4"/>

                    <!-- Filtros de relatórios -->
                    <StackPanel Spacing="8" Margin="0,0,0,4">
                        <!-- Busca textual + contador + exportar CSV -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="{ThemeResource InputBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Height="36">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{ThemeResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" Margin="10,0,8,0"/>
                                    <TextBox x:Name="BuscaRelBox" Grid.Column="1"
                                             PlaceholderText="Buscar por obra, número do RDO..."
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{ThemeResource TextPrimaryBrush}"
                                             VerticalAlignment="Center"
                                             TextChanged="BuscaRel_TextChanged"/>
                                </Grid>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="ContadorRelTexto"
                                       FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Height="36" Padding="12,0"
                                    Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    Foreground="{ThemeResource AccentBrush}"
                                    FontSize="12"
                                    ToolTipService.ToolTip="Exportar lista filtrada como CSV"
                                    Click="ExportarCsv_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="12"
                                              Foreground="{ThemeResource AccentBrush}"/>
                                    <TextBlock Text="Exportar CSV"
                                               Foreground="{ThemeResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <ListView x:Name="MeusRelatoriosListView"
                              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="20,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0"
                                                   Fill="{ThemeResource AccentBrush}"
                                                   RadiusX="2" RadiusY="2"/>
                                        <StackPanel Grid.Column="1" Spacing="4"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ObraNome}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding NumeroFormatado}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource AccentBrush}"/>
                                                <TextBlock Text="{Binding RevisaoFormatada}"
                                                           FontSize="11"
                                                           Foreground="#C896FF"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DataFormatada}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding FuncionariosPresentes}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="2"
                                                Background="{ThemeResource AccentSubtleBgBrush}"
                                                BorderBrush="{ThemeResource AccentBrush}" BorderThickness="1"
                                                CornerRadius="4" Padding="10,4"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource AccentBrush}"/>
                                        </Border>
                                        <!-- Botão Editar -->
                                        <Button Grid.Column="3"
                                                Tag="{Binding}"
                                                Content="&#xE70F;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="14"
                                                Width="36" Height="36" Padding="0"
                                                Background="{ThemeResource EditBtnBgBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                                Foreground="{ThemeResource AccentBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                ToolTipService.ToolTip="Editar relatório"
                                                Click="BtnEditarRelatorio_Click"/>
                                        <!-- Botão Exportar -->
                                        <Button Grid.Column="4"
                                                Tag="{Binding Id}"
                                                Content="&#xE8C8;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="16"
                                                Width="36" Height="36" Padding="0"
                                                Background="{ThemeResource EditBtnBgBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                                Foreground="{ThemeResource AccentBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                ToolTipService.ToolTip="Exportar PDF"
                                                Click="BtnExportarPdfItem_Click"/>
                                        <!-- Botão Excluir -->
                                        <Button Grid.Column="5"
                                                Tag="{Binding Id}"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13"
                                                Width="36" Height="36" Padding="0"
                                                Background="#261010"
                                                BorderBrush="#5A1E1E" BorderThickness="1"
                                                Foreground="#E65050"
                                                VerticalAlignment="Center"
                                                ToolTipService.ToolTip="Excluir relatório"
                                                Click="BtnExcluirRelatorio_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <!-- Painel de Rascunhos (integrado na MainPage) -->
            <ScrollViewer x:Name="RascunhosPanel"
                          Grid.Row="3"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          Padding="28">
                <Grid>
                <StackPanel Spacing="12">
                    <TextBlock Text="RASCUNHOS" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="150" Margin="0,0,0,4"/>

                    <!-- Filtros de rascunhos -->
                    <StackPanel Spacing="8" Margin="0,0,0,4">
                        <!-- Busca textual -->
                        <Border Background="{ThemeResource InputBgBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="13"
                                          Foreground="{ThemeResource TextTertiaryBrush}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" x:Name="BuscaRascBox"
                                         PlaceholderText="Buscar por obra ou responsável..."
                                         Height="36" Background="Transparent" BorderThickness="0"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         VerticalAlignment="Center"
                                         TextChanged="BuscaRasc_TextChanged"/>
                            </Grid>
                        </Border>
                        <!-- Dropdowns -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FiltroObraRascBox" Grid.Column="0"
                                      PlaceholderText="Todas as obras"
                                      HorizontalAlignment="Stretch" Height="36"
                                      Background="{ThemeResource InputBgBrush}"
                                      BorderBrush="{ThemeResource AppBorderBrush}"
                                      Foreground="{ThemeResource TextPrimaryBrush}"
                                      SelectionChanged="FiltroRasc_Changed"/>
                            <ComboBox x:Name="FiltroRespRascBox" Grid.Column="1"
                                      PlaceholderText="Todos os responsáveis"
                                      HorizontalAlignment="Stretch" Height="36"
                                      Background="{ThemeResource InputBgBrush}"
                                      BorderBrush="{ThemeResource AppBorderBrush}"
                                      Foreground="{ThemeResource TextPrimaryBrush}"
                                      SelectionChanged="FiltroRasc_Changed"/>
                            <Button Grid.Column="2" Content="Limpar" Height="36"
                                    Background="Transparent"
                                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                    Foreground="{ThemeResource TextSecondaryBrush}"
                                    FontSize="12" Padding="14,0"
                                    Click="LimparFiltrosRasc_Click"/>
                        </Grid>
                    </StackPanel>

                    <ListView x:Name="RascunhosListView"
                              SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource PanelBgBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="20,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Barra lateral amarela -->
                                        <Rectangle Grid.Column="0" Fill="#f59e0b"
                                                   RadiusX="2" RadiusY="2"/>
                                        <!-- Informações -->
                                        <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ObraNome}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding NumeroFormatado}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource AccentBrush}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding DataRelatorio}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                                <TextBlock Text="·" FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                                <TextBlock Text="{Binding CriadoPor}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextTertiaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SalvoEm}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                        <!-- Badge Rascunho -->
                                        <Border Grid.Column="2"
                                                Background="#3D2E00"
                                                BorderBrush="#f59e0b" BorderThickness="1"
                                                CornerRadius="4" Padding="10,4"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="Rascunho" FontSize="11"
                                                       Foreground="#f59e0b"/>
                                        </Border>
                                        <!-- Botão Continuar -->
                                        <Button Grid.Column="3"
                                                Content="&#xE70F;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="14" Width="36" Height="36" Padding="0"
                                                Background="{ThemeResource EditBtnBgBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                                Foreground="{ThemeResource AccentBrush}"
                                                VerticalAlignment="Center" Margin="0,0,4,0"
                                                ToolTipService.ToolTip="Continuar editando"
                                                Tag="{Binding ObraId}"
                                                Click="ContinuarRascunho_Click"/>
                                        <!-- Botão Excluir -->
                                        <Button Grid.Column="4"
                                                Content="&#xE74D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="13" Width="36" Height="36" Padding="0"
                                                Background="#261010"
                                                BorderBrush="#5A1E1E" BorderThickness="1"
                                                Foreground="#E65050"
                                                VerticalAlignment="Center"
                                                ToolTipService.ToolTip="Excluir rascunho"
                                                Tag="{Binding Id}"
                                                Click="ExcluirRascunho_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Contador oculto (usado no code-behind) -->
                    <TextBlock x:Name="TotalRascunhosTexto" Text="0" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Estado vazio (sobreposto via Grid) -->
                <StackPanel x:Name="RascunhosEmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12">
                    <FontIcon Glyph="&#xE70B;" FontSize="48"
                              Foreground="{ThemeResource TextTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Nenhum rascunho encontrado"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Os relatórios salvos como rascunho aparecerão aqui."
                               FontSize="13"
                               Foreground="{ThemeResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
