<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.RascunhosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Button Content="← Voltar" Click="VoltarBtn_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Text="Rascunhos" FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock Text="RELATÓRIOS EM RASCUNHO" FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentBrush}"
                           CharacterSpacing="150" Margin="0,0,0,8"/>
                <ListView x:Name="RascunhosListView"
                          SelectionMode="None" Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource PanelBgBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="20,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#f59e0b"
                                               RadiusX="2" RadiusY="2"/>
                                    <StackPanel Grid.Column="1" Spacing="4"
                                                Margin="12,0,0,0">
                                        <TextBlock Text="{Binding ObraNome}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding DataFormatada}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11" Foreground="#f59e0b"/>
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Content="Continuar"
                                            Margin="0,0,8,0"
                                            Height="34" Padding="14,0"
                                            Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                            Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                            Tag="{Binding ObraId}"
                                            Click="ContinuarRascunho_Click"/>
                                    <Button Grid.Column="3"
                                            Content="🗑" Width="34" Height="34"
                                            Background="#1a1212"
                                            BorderBrush="#3a1a1a" BorderThickness="1"
                                            Foreground="#ff6666" Padding="0"
                                            Tag="{Binding Id}"
                                            Click="ExcluirRascunho_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
