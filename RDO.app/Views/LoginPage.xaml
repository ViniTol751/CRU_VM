<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo — imagem -->
        <Grid Grid.Column="0">
            <Image Source="ms-appx:///Assets/subestacao.png"
                   Stretch="UniformToFill"/>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#AA0a0e1a" Offset="0"/>
                        <GradientStop Color="#550a0e1a" Offset="0.7"/>
                        <GradientStop Color="#000a0e1a" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Painel direito — formulário -->
        <Grid Grid.Column="1" Background="{ThemeResource PanelBgBrush}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="360" Spacing="28">

                <!-- Título -->
                <StackPanel Spacing="6">
                    <TextBlock Text="ENTRAR NO SISTEMA" FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource AccentBrush}"
                               CharacterSpacing="180"/>
                    <TextBlock Text="Digite seus dados de acesso"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Campos -->
                <StackPanel Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="E-MAIL DE ACESSO" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextSecondaryBrush}"
                                   CharacterSpacing="150"/>
                        <TextBox x:Name="EmailBox"
                                 PlaceholderText="nome@empresa.com.br"
                                 Background="{ThemeResource InputBgBrush}"
                                 BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                 Foreground="{ThemeResource TextPrimaryBrush}" Height="46"
                                 HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Text="SENHA DE ACESSO" FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       CharacterSpacing="150"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="EsqueceuSenhaBtn"
                                    Content="Esqueceu a senha?"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{ThemeResource AccentBrush}" FontSize="12"
                                    Padding="0"
                                    Click="EsqueceuSenhaBtn_Click"/>
                        </Grid>
                        <PasswordBox x:Name="SenhaBox"
                                     PlaceholderText="Digite sua senha"
                                     Background="{ThemeResource InputBgBrush}"
                                     BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                                     Foreground="{ThemeResource TextPrimaryBrush}" Height="46"
                                     HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <TextBlock x:Name="ErroTexto"
                               Foreground="#ff4444" FontSize="13"
                               Visibility="Collapsed" TextWrapping="Wrap"/>

                    <Button x:Name="EntrarBtn"
                            Content="ENTRAR"
                            HorizontalAlignment="Stretch" Height="46"
                            Background="{ThemeResource AccentBrush}" BorderThickness="0"
                            Foreground="{ThemeResource AccentFgBrush}" FontWeight="Bold"
                            FontSize="13" CharacterSpacing="150"
                            Click="EntrarBtn_Click"/>
                </StackPanel>

                <TextBlock Text="Versão 1.0 — RDO App" FontSize="11"
                           Foreground="{ThemeResource AppBorderBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
