<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}"
    Loaded="LoginPage_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo — imagem -->
        <Grid Grid.Column="0">
            <Image x:Name="LoginSideImage"
                   Source="ms-appx:///Assets/SE_Dark.png"
                   Stretch="UniformToFill"/>
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#AA0a0e1a" Offset="0"/>
                        <GradientStop Color="#550a0e1a" Offset="0.7"/>
                        <GradientStop Color="#000a0e1a" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <!-- Painel direito — formulário -->
        <Grid Grid.Column="1" Background="{ThemeResource PanelBgBrush}">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="340" Spacing="0">

                <!-- Título -->
                <StackPanel Spacing="6" Margin="0,0,0,32">
                    <TextBlock Text="Iniciar Sessão"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Insira suas credenciais para acessar o sistema."
                               FontSize="12"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Campo USUÁRIO -->
                <StackPanel Spacing="6" Margin="0,0,0,16">
                    <TextBlock Text="USUÁRIO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               CharacterSpacing="150"/>
                    <Border Background="{ThemeResource InputBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="4" Height="46">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,0,1,0">
                                <FontIcon Glyph="&#xE77B;" FontSize="15"
                                          Foreground="{ThemeResource AccentBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <TextBox x:Name="EmailBox"
                                     Grid.Column="1"
                                     PlaceholderText="Ex: vinicius.toledo"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     VerticalAlignment="Center"
                                     Padding="10,0"
                                     GotFocus="EmailBox_GotFocus"
                                     LostFocus="EmailBox_LostFocus"
                                     TextChanged="EmailBox_TextChanged"
                                     KeyDown="LoginField_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Sugestões de login salvo -->
                    <Border x:Name="SuggestionsContainer"
                            Background="{ThemeResource PanelBgBrush}"
                            BorderBrush="{ThemeResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            MaxHeight="160"
                            Visibility="Collapsed">
                        <ListView x:Name="SuggestionsList"
                                  IsItemClickEnabled="True"
                                  SelectionMode="None"
                                  ItemClick="SuggestionsList_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,2">
                                        <FontIcon Glyph="&#xE77B;" FontSize="12"
                                                  Foreground="{ThemeResource AccentBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>

                <!-- Campo SENHA DE ACESSO -->
                <StackPanel Spacing="6" Margin="0,0,0,12">
                    <TextBlock Text="SENHA DE ACESSO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               CharacterSpacing="150"/>
                    <Border Background="{ThemeResource InputBgBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="4" Height="46">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="0,0,1,0">
                                <FontIcon Glyph="&#xE72E;" FontSize="14"
                                          Foreground="{ThemeResource AccentBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <PasswordBox x:Name="SenhaBox"
                                         Grid.Column="1"
                                         PlaceholderText="Digite sua senha"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         VerticalAlignment="Center"
                                         Padding="10,0"
                                         PasswordRevealMode="Peek"
                                         KeyDown="LoginField_KeyDown"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Lembrar + Esqueceu -->
                <Grid Margin="0,0,0,12">
                    <CheckBox x:Name="LembrarCheck"
                              Content="Lembrar dispositivo"
                              FontSize="12"
                              Foreground="{ThemeResource TextSecondaryBrush}"/>
                    <Button x:Name="EsqueceuSenhaBtn"
                            Content="ESQUECEU A SENHA?"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource AccentBrush}"
                            FontSize="10" FontWeight="SemiBold"
                            CharacterSpacing="100" Padding="0"
                            Click="EsqueceuSenhaBtn_Click"/>
                </Grid>

                <!-- Erro -->
                <TextBlock x:Name="ErroTexto"
                           Foreground="#ff4444" FontSize="12"
                           Visibility="Collapsed" TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Botão principal -->
                <Button x:Name="EntrarBtn"
                        Content="AUTENTICAR"
                        HorizontalAlignment="Stretch" Height="46"
                        Background="{ThemeResource AccentBrush}" BorderThickness="0"
                        Foreground="{ThemeResource AccentFgBrush}"
                        FontWeight="Bold" FontSize="13" CharacterSpacing="200"
                        CornerRadius="4"
                        Click="EntrarBtn_Click"/>

                <!-- Registrar conta -->
                <Button x:Name="RegistrarBtn"
                        Content="REGISTRAR CONTA"
                        HorizontalAlignment="Stretch" Height="46"
                        Background="Transparent"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        Foreground="{ThemeResource AccentBrush}"
                        FontWeight="SemiBold" FontSize="13" CharacterSpacing="100"
                        CornerRadius="4"
                        Margin="0,8,0,0"
                        Click="RegistrarBtn_Click"/>

                <!-- Alterar tema -->
                <Button x:Name="BtnTema"
                        Content="&#xE706;"
                        FontFamily="Segoe MDL2 Assets"
                        Width="32" Height="32" Padding="0"
                        Background="Transparent"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        Foreground="{ThemeResource AccentBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0"
                        ToolTipService.ToolTip="Alternar tema"
                        Click="BtnTema_Click"/>

                <!-- Versão -->
                <TextBlock Text="Versão 1.0 — RDO App" FontSize="10"
                           Foreground="{ThemeResource AppBorderBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
