<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RDO.App.Views.RdoFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{ThemeResource PanelBgBrush}"
        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="12"
                    VerticalAlignment="Center">
                    <Button Content="← Voltar" Click="VoltarBtn_Click"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock x:Name="TituloObra" FontSize="15"
                       FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Novo RDO" FontSize="15"
                       FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}"/>
                    <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="4" Padding="8,2">
                        <TextBlock x:Name="NumeroRdoTexto" FontSize="12"
                           Foreground="{ThemeResource AccentBrush}"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="10">

                    <Border x:Name="StatusBadge"
                    CornerRadius="4"
                    Height="34"
                    MinWidth="120"
                    Padding="16,0"
                    VerticalAlignment="Center">
                        <TextBlock x:Name="StatusBadgeTexto"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                    </Border>

                    <Button Content="SALVAR RDO"
                    Height="34"
                    Padding="16,0"
                    Background="{ThemeResource AccentBrush}"
                    BorderThickness="0"
                    Foreground="{ThemeResource AccentFgBrush}"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Click="SalvarBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scroll principal -->
        <ScrollViewer Grid.Row="1" Padding="24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="0,0,0,32">

                <!-- ── DADOS GERAIS ── -->
                <Border Background="{ThemeResource PanelBgBrush}"
        BorderBrush="{ThemeResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="6"
        Padding="24">

                    <StackPanel Spacing="16">
                        <TextBlock Text="DADOS GERAIS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource AccentBrush}"
                   CharacterSpacing="150"/>

                        <Grid ColumnSpacing="20"
              HorizontalAlignment="Center"
              MaxWidth="1260"
              VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Data -->
                            <StackPanel Grid.Column="0"
                        Spacing="6"
                        VerticalAlignment="Center">
                                <TextBlock Text="DATA"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           CharacterSpacing="100"/>

                                <Border Background="{ThemeResource AppBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Height="38"
                        Padding="10,0"
                        VerticalAlignment="Center">

                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock x:Name="DataTexto"
                                   Grid.Column="0"
                                   Text="24/03/2026"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                                        <Button Grid.Column="1"
                                x:Name="AbrirCalendarioBtn"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="AbrirCalendarioBtn_Click">
                                            <FontIcon Glyph="&#xE787;"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextPrimaryBrush}"/>
                                        </Button>

                                        <CalendarDatePicker x:Name="DataPicker"
                                            Opacity="0"
                                            Width="1"
                                            Height="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            DateChanged="DataPicker_DateChanged"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Responsável Focus -->
                            <StackPanel Grid.Column="1"
                        Spacing="6"
                        VerticalAlignment="Center">
                                <TextBlock Text="RESPONSÁVEL FOCUS"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           CharacterSpacing="100"/>

                                <ComboBox x:Name="ResponsavelBox"
                          Height="38"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="{ThemeResource AppBgBrush}"
                          BorderBrush="{ThemeResource AppBorderBrush}"
                          Foreground="{ThemeResource TextPrimaryBrush}"
                          PlaceholderText="Selecione"
                          SelectionChanged="ResponsavelBox_SelectionChanged">
                                    <ComboBoxItem Content="Bruno Pires"/>
                                    <ComboBoxItem Content="Felipe Prado"/>
                                    <ComboBoxItem Content="Juliana Bertoni"/>
                                    <ComboBoxItem Content="Maicon Salomão"/>
                                    <ComboBoxItem Content="Murilo Franco"/>
                                    <ComboBoxItem Content="Wellington Bortolozo"/>
                                    <ComboBoxItem Content="Wesley Gregório"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- CREA -->
                            <StackPanel Grid.Column="2"
                        Spacing="6"
                        VerticalAlignment="Center">
                                <TextBlock Text="CREA"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           CharacterSpacing="100"/>

                                <Border Background="{ThemeResource AppBgBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,0"
                        Height="38"
                        VerticalAlignment="Center">
                                    <TextBlock x:Name="CreaTexto"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextTertiaryBrush}"
                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Status -->
                            <StackPanel Grid.Column="3"
                        Spacing="6"
                        VerticalAlignment="Center">
                                <TextBlock Text="STATUS"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           CharacterSpacing="100"/>

                                <ComboBox x:Name="StatusBox"
                          Height="38"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="{ThemeResource AppBgBrush}"
                          BorderBrush="{ThemeResource AppBorderBrush}"
                          Foreground="{ThemeResource TextPrimaryBrush}"
                          SelectionChanged="StatusBox_SelectionChanged">
                                    <ComboBoxItem Content="Rascunho"/>
                                    <ComboBoxItem Content="Publicado"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource PanelBgBrush}"
        BorderBrush="{ThemeResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="6"
        Padding="24">

                    <StackPanel Spacing="12">

                        <TextBlock Text="CONDIÇÃO CLIMÁTICA"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource AccentBrush}"
                   CharacterSpacing="150"/>

                        <Border Background="{ThemeResource AppBgBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                HorizontalAlignment="Center">

                            <StackPanel Spacing="0">

                                <Border BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="18,12">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="125"/>
                                            <ColumnDefinition Width="135"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="PERÍODO" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100" VerticalAlignment="Center"/>

                                        <Border Grid.Column="1" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="☀" FontSize="11"/>
                                                <TextBlock Text="ENSOLARADO" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="40"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="⛅" FontSize="11"/>
                                                <TextBlock Text="NUBLADO" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="40"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="🌧" FontSize="11"/>
                                                <TextBlock Text="CHUVOSO" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="40"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="4" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <TextBlock Text="PRATICÁVEL" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" CharacterSpacing="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <Border Grid.Column="5" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <TextBlock Text="IMPRATICÁVEL" FontSize="9" FontWeight="SemiBold" Foreground="#ff7a7a" CharacterSpacing="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="125"/>
                                            <ColumnDefinition Width="135"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="MANHÃ" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="60"/>
                                            <TextBlock Text="06h–12h" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="ManhaEnsolarado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="ManhaNublado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="3" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="ManhaChuvoso" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="4" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="ManhaPraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="5" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="ManhaImpraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="125"/>
                                            <ColumnDefinition Width="135"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="TARDE" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="60"/>
                                            <TextBlock Text="12h–18h" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="TardeEnsolarado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="TardeNublado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="3" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="TardeChuvoso" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="4" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="TardePraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="5" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="TardeImpraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Padding="18,14">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="125"/>
                                            <ColumnDefinition Width="135"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="NOITE" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextTertiaryBrush}" CharacterSpacing="60"/>
                                            <TextBlock Text="18h–06h" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="NoiteEnsolarado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="NoiteNublado" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="3" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="NoiteChuvoso" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="4" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="NoitePraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                        <Border Grid.Column="5" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0">
                                            <CheckBox x:Name="NoiteImpraticavel" HorizontalAlignment="Center" MinWidth="32" Width="32" Padding="0"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── EQUIPE ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="EQUIPE DO DIA" FontSize="11"
                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorEquipe" Text="0"
                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>

                            <Button Content="+ Adicionar funcionário"
                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                    Click="AdicionarFuncionario_Click"/>
                        </Grid>

                        <Border Background="{ThemeResource AppBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="215"/>
                                    <ColumnDefinition Width="255"/>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="245"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NOME" FontSize="9"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="EMPRESA" FontSize="9" 
                                           HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="ENTRADA" FontSize="9"
                                           HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="SAÍDA" FontSize="9"
                                           HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="INTERVALO" FontSize="9"
                                           HorizontalAlignment="Center" TextAlignment="Center"  VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="5" Text="HS. TRAB." FontSize="9"
                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="FuncionariosPanel" Spacing="4"/>
                    </StackPanel>
                </Border>

                <!-- ── EQUIPAMENTOS ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="EQUIPAMENTOS UTILIZADOS" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorEquipamentos" Text="0"
                                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="+ Adicionar equipamento"
                                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                    Click="AdicionarEquipamento_Click"/>
                        </Grid>
                        <Border Background="{ThemeResource AppBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PATRIMÔNIO" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                <TextBlock Grid.Column="1" Text="EQUIPAMENTO" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                <TextBlock Grid.Column="2" Text="FABRICANTE / MODELO" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="EquipamentosPanel" Spacing="4"/>
                    </StackPanel>
                </Border>

                <!-- ── ACOMPANHANTES ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="ACOMPANHANTES TÉCNICOS" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorAcompanhantes" Text="0"
                                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="+ Adicionar acompanhante"
                                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                    Click="AdicionarAcompanhante_Click"/>
                        </Grid>
                        <Border Background="{ThemeResource AppBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NOME" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                                <TextBlock Grid.Column="1" Text="CARGO" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"
                                           Margin = "8,0,0,0" />
                                <TextBlock Grid.Column="2" Text="GRUPO / CLIENTE" FontSize="9"
                                           FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" CharacterSpacing="100"/>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="AcompanhantesPanel" Spacing="4"/>
                    </StackPanel>
                </Border>

                <!-- ── ATIVIDADES ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="ATIVIDADES EXECUTADAS" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorAtividades" Text="0"
                                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="+ Adicionar atividade"
                                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                    Click="AdicionarAtividade_Click"/>
                        </Grid>
                        <StackPanel x:Name="AtividadesPanel" Spacing="8"/>
                    </StackPanel>
                </Border>

                <!-- ── OCORRÊNCIAS ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="OCORRÊNCIAS" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorOcorrencias" Text="0"
                                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="+ Adicionar ocorrência"
                                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                    Click="AdicionarOcorrencia_Click"/>
                        </Grid>
                        <StackPanel x:Name="OcorrenciasPanel" Spacing="8"/>
                    </StackPanel>
                </Border>

                <!-- ── FOTOS ── -->
                <Border Background="{ThemeResource PanelBgBrush}" BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="24">
                    <StackPanel Spacing="12">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="FOTOS DO DIA" FontSize="11"
                                           FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"
                                           CharacterSpacing="150"/>
                                <Border Background="{ThemeResource AppBorderBrush}" CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="ContadorFotos" Text="0"
                                               FontSize="11" Foreground="{ThemeResource TextTertiaryBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="+ Adicionar foto"
                                    HorizontalAlignment="Right" Height="34" Padding="14,0"
                                    Background="{ThemeResource AccentBrush}" BorderThickness="0"
                                    Foreground="{ThemeResource AccentFgBrush}" FontWeight="SemiBold"
                                    Click="AdicionarFoto_Click"/>
                        </Grid>
                        <StackPanel x:Name="FotosWrapPanel" Orientation="Horizontal"
                                    Spacing="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>