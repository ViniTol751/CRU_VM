<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RDO.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RDO">

    <Grid>
        <Frame x:Name="RootFrame"/>

        <!-- Faixa de title bar customizada — botões nativos ficam sobrepostos pelo sistema -->
        <Grid x:Name="AppTitleBar" Height="32" VerticalAlignment="Top"
              Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>

            <Rectangle x:Name="TitleBarBg" Grid.Row="0"
                       Fill="{ThemeResource NavBgBrush}"/>

            <StackPanel x:Name="TitleBarContent" Grid.Row="0" Orientation="Horizontal"
                        Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image x:Name="TitleBarIcon"
                       Width="16" Height="16" Stretch="Uniform"
                       VerticalAlignment="Center"/>
                <TextBlock Text="RDO · Relatório Diário de Obra"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Rectangle x:Name="TitleBarDivider" Grid.Row="1"
                       Fill="{ThemeResource AppBorderBrush}"/>
        </Grid>
    </Grid>
</Window>
