<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RDO.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RDO">
    <Grid>
        <!-- Frame ocupa toda a altura da janela -->
        <Frame x:Name="RootFrame"/>

        <!-- Title bar sobreposta no topo -->
        <Grid x:Name="AppTitleBar" Height="44" VerticalAlignment="Top"
              Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
            </Grid.RowDefinitions>

            <!-- Fundo sólido — visível fora do login, oculto no login -->
            <Rectangle x:Name="TitleBarBg" Grid.Row="0"
                       Fill="{ThemeResource NavBgBrush}"/>

            <!-- Logo + título -->
            <StackPanel x:Name="TitleBarContent" Grid.Row="0" Orientation="Horizontal"
                        Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image x:Name="TitleBarIcon"
                       Width="26" Height="26" Stretch="Uniform"
                       VerticalAlignment="Center"/>
                <TextBlock Text="RDO · Relatório Diário de Obra"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Linha divisória inferior — visível fora do login -->
            <Rectangle x:Name="TitleBarDivider" Grid.Row="1"
                       Fill="{ThemeResource AppBorderBrush}"/>
        </Grid>
    </Grid>
</Window>
