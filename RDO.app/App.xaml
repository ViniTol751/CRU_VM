<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RDO.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ── TEMA ESCURO ─────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#1f1f1f"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#181818"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#2b2d31"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#007fd4"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#ffffff"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#cccccc"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#9d9d9d"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#6a6a6a"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#252526"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#111111"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#333333"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#004b7a"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#5a1d1d"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#8c2a2a"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#f14c4c"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#181818"/>
                    <Color x:Key="AppBgColor">#1f1f1f</Color>
                    <Color x:Key="BorderColor">#2b2d31</Color>
                </ResourceDictionary>

                <!-- ── TEMA CLARO ──────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#d5d6db"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#e1e2e7"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#a8aecb"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#2e7de9"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#ffffff"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#343b58"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#565f89"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#9699a3"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#cbccd1"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#b4b5b9"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#c0c2cd"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#a8aecb"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#ffcccc"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#f52a65"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#8c4351"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#e1e2e7"/>
                    <Color x:Key="AppBgColor">#d5d6db</Color>
                    <Color x:Key="BorderColor">#a8aecb</Color>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
