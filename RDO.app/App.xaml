<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RDO.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ── TEMA ESCURO (Siemens) ──────────────────────────────── -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#0a0e1a"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#0d1526"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#1e2d4a"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#00c8a0"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#0a0e1a"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="White"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#4a6080"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#8ab4d4"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#080c18"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#0a1526"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#12263a"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#0a1f1a"/>
                    <Color x:Key="AppBgColor">#0a0e1a</Color>
                    <Color x:Key="BorderColor">#1e2d4a</Color>
                </ResourceDictionary>

                <!-- ── TEMA CLARO (Focus Engenharia Elétrica) ─────────────── -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#dde3ec"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#eaeff6"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#bccbdc"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#0052cc"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#ffffff"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#1a2a3a"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#4e6278"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#506070"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#e2e8f2"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#cfd8e8"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#d0e2f8"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#d5e5ff"/>
                    <Color x:Key="AppBgColor">#dde3ec</Color>
                    <Color x:Key="BorderColor">#bccbdc</Color>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
