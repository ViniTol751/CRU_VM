<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RDO.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ── TEMA ESCURO ─────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#1A1A2E"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#2D2D3D"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#3A3A52"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#2DD4A8"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#102026"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#C9D4E2"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#67E8F9"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#232337"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#24263A"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#1F2B3A"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#1B3A3A"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#3A1F27"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#7B2E42"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#FF8BA7"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#1F2030"/>
                    <Color x:Key="AppBgColor">#1A1A2E</Color>
                    <Color x:Key="BorderColor">#3A3A52</Color>
                </ResourceDictionary>

                <!-- ── TEMA CLARO ──────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#F0F4F8"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#D7E1EC"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#3B82F6"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#1E3A5F"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#334155"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#6BA3C8"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#E6EEF8"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#EAF2FF"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#DBEAFE"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#FEE2E2"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#FCA5A5"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#B91C1C"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#1E3A5F"/>
                    <Color x:Key="AppBgColor">#F0F4F8</Color>
                    <Color x:Key="BorderColor">#D7E1EC</Color>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
