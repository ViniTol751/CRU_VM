<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RDO.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ── TEMA ESCURO ─────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#1f1f1f"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#181818"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#2b2d31"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#2563eb"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#ffffff"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#cccccc"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#9d9d9d"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#6a6a6a"/>
                    <SolidColorBrush x:Key="IconBrush"            Color="#b0b4bc"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#252526"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#111111"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#333333"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#1e3a78"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#5a1d1d"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#8c2a2a"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#f14c4c"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#181818"/>
                    </ResourceDictionary>

                <!-- ── TEMA CLARO ──────────────────────────────────────────── -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBgBrush"           Color="#c8cad2"/>
                    <SolidColorBrush x:Key="PanelBgBrush"         Color="#dddee5"/>
                    <SolidColorBrush x:Key="AppBorderBrush"       Color="#8892b8"/>
                    <SolidColorBrush x:Key="AccentBrush"          Color="#2563eb"/>
                    <SolidColorBrush x:Key="AccentFgBrush"        Color="#ffffff"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="#1e2433"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="#424b6e"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush"    Color="#5e6680"/>
                    <SolidColorBrush x:Key="IconBrush"            Color="#2e3142"/>
                    <SolidColorBrush x:Key="InputBgBrush"         Color="#c8cad2"/>
                    <SolidColorBrush x:Key="CardImgBgBrush"       Color="#9ea3b2"/>
                    <SolidColorBrush x:Key="EditBtnBgBrush"       Color="#b8bac8"/>
                    <SolidColorBrush x:Key="AccentSubtleBgBrush"  Color="#c4cae8"/>
                    <SolidColorBrush x:Key="DangerBgBrush"        Color="#ffcccc"/>
                    <SolidColorBrush x:Key="DangerBorderBrush"    Color="#f52a65"/>
                    <SolidColorBrush x:Key="DangerFgBrush"        Color="#8c4351"/>
                    <SolidColorBrush x:Key="NavBgBrush"           Color="#d4d6e0"/>
                    </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
